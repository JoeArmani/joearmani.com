{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "joearmani",
  "compatibility_date": "2026-03-23",
  "assets": {
    "directory": "./dist"
  },
  "routes": [
    { "pattern": "joearmani.com", "custom_domain": true },
    { "pattern": "www.joearmani.com", "custom_domain": true }
  ]
}
