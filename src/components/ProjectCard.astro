---
interface Props {
  title: string;
  description: string;
  status: string;
  tags: string[];
  slug: string;
  headingLevel?: 2 | 3;
  links?: {
    github?: string;
    live?: string;
    appStore?: string;
    playStore?: string;
  };
}

const { title, description, status, tags, slug, headingLevel = 3, links } = Astro.props;

const statusClass = `status-badge--${status.toLowerCase()}`;
const hasLinks = links && (links.github || links.live || links.appStore || links.playStore);
const Heading = `h${headingLevel}` as any;
---

<article class="card card--project">
  <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
    <Heading class="card__title" style="margin-bottom: 0;">
      <a href={`/projects/${slug}`}>{title}</a>
    </Heading>
    <span class={`status-badge ${statusClass}`}>{status}</span>
  </div>
  <p class="card__excerpt">{description}</p>
  <div class="tags" style="margin-top: 0.75rem;">
    {tags.map((tag) => (
      <span class="tag">{tag}</span>
    ))}
  </div>
  {hasLinks && (
    <div style="display: flex; gap: 0.75rem; margin-top: 1rem;">
      {links!.github && <a href={links!.github} class="btn btn--outline" style="padding: 0.4rem 1rem; font-size: 0.85rem;" target="_blank" rel="noopener noreferrer">GitHub</a>}
      {links!.live && <a href={links!.live} class="btn btn--outline" style="padding: 0.4rem 1rem; font-size: 0.85rem;" target="_blank" rel="noopener noreferrer">Live Site</a>}
      {links!.appStore && <a href={links!.appStore} class="btn btn--outline" style="padding: 0.4rem 1rem; font-size: 0.85rem;" target="_blank" rel="noopener noreferrer">App Store</a>}
      {links!.playStore && <a href={links!.playStore} class="btn btn--outline" style="padding: 0.4rem 1rem; font-size: 0.85rem;" target="_blank" rel="noopener noreferrer">Play Store</a>}
    </div>
  )}
</article>
