---
/**
 * DiagramZoom — click-to-expand wrapper for inline-SVG diagrams.
 *
 * Targets every `figure.diagram` on the page. On click (or Enter / Space when
 * focused), opens a full-viewport <dialog> showing the same diagram at the
 * largest size that fits, with native pinch-zoom and scroll on touch devices.
 *
 * Drop this once in a layout. It is render-only — emits a <style is:global>
 * and a <script> and nothing visible.
 */
---

<style is:global>
  figure.diagram {
    cursor: zoom-in;
    position: relative;
    /*
     * Light "card" background so the SVG title, subtitle, and legend —
     * which sit outside the diagram's internal lane backgrounds —
     * render on a light surface in both light and dark mode. The diagrams
     * themselves are designed against a light palette and aren't theme-aware.
     */
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 1rem 1.25rem 0.75rem;
    margin-top: 2rem;
    margin-bottom: 2rem;
  }

  figure.diagram figcaption {
    color: #334155;
    margin-top: 0.5rem;
  }

  figure.diagram::after {
    content: "⤢";
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: rgba(15, 23, 42, 0.78);
    color: #fff;
    font-size: 14px;
    line-height: 28px;
    text-align: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  figure.diagram:hover::after,
  figure.diagram:focus-visible::after {
    opacity: 1;
  }

  figure.diagram:focus-visible {
    outline: 2px solid var(--accent-blue, #2563eb);
    outline-offset: 4px;
  }

  dialog.diagram-zoom {
    width: 100vw;
    width: 100dvw;
    height: 100vh;
    height: 100dvh;
    max-width: 100vw;
    max-height: 100vh;
    margin: 0;
    padding: 0;
    border: 0;
    background: rgba(15, 23, 42, 0.96);
    overflow: auto;
    -webkit-overflow-scrolling: touch;
    touch-action: pinch-zoom;
    overscroll-behavior: contain;
  }

  dialog.diagram-zoom::backdrop {
    background: rgba(15, 23, 42, 0.96);
  }

  dialog.diagram-zoom .zoom-content {
    min-height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    box-sizing: border-box;
  }

  dialog.diagram-zoom figure.diagram {
    cursor: default;
    margin: 0;
    width: min(100%, 1600px);
    background: #fff;
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.55);
  }

  dialog.diagram-zoom figure.diagram::after {
    display: none;
  }

  dialog.diagram-zoom figure.diagram svg {
    width: 100%;
    height: auto;
    max-width: none;
    display: block;
  }

  dialog.diagram-zoom figure.diagram figcaption {
    margin-top: 0.75rem;
    font-size: 0.95rem;
    color: #334155;
  }

  dialog.diagram-zoom .zoom-close {
    position: fixed;
    top: 1rem;
    right: 1rem;
    width: 44px;
    height: 44px;
    border-radius: 22px;
    border: 0;
    background: #fff;
    color: #0f172a;
    font-size: 22px;
    font-weight: 700;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.45);
    z-index: 1;
  }

  dialog.diagram-zoom .zoom-close:hover,
  dialog.diagram-zoom .zoom-close:focus-visible {
    background: #f1f5f9;
  }

  dialog.diagram-zoom .zoom-hint {
    position: fixed;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.8rem;
    color: rgba(241, 245, 249, 0.85);
    background: rgba(15, 23, 42, 0.6);
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
    pointer-events: none;
  }

  @media (max-width: 640px) {
    dialog.diagram-zoom .zoom-content {
      padding: 0.5rem;
      align-items: flex-start;
    }
    dialog.diagram-zoom figure.diagram {
      padding: 0.75rem;
    }
    dialog.diagram-zoom .zoom-hint {
      font-size: 0.75rem;
    }
  }
</style>

<script>
  function initDiagramZoom() {
    const figures = document.querySelectorAll<HTMLElement>('figure.diagram');
    if (figures.length === 0) return;

    let dialog = document.querySelector<HTMLDialogElement>('dialog.diagram-zoom');
    if (!dialog) {
      dialog = document.createElement('dialog');
      dialog.className = 'diagram-zoom';
      dialog.innerHTML = `
        <button type="button" class="zoom-close" aria-label="Close diagram">×</button>
        <div class="zoom-content"></div>
        <div class="zoom-hint" aria-hidden="true">Pinch or scroll to zoom · Esc to close</div>
      `;
      document.body.appendChild(dialog);

      const closeBtn = dialog.querySelector('.zoom-close')!;
      closeBtn.addEventListener('click', () => dialog!.close());
      dialog.addEventListener('click', (e) => {
        if (e.target === dialog) dialog!.close();
      });
      dialog.addEventListener('close', () => {
        const slot = dialog!.querySelector('.zoom-content')!;
        slot.innerHTML = '';
      });
    }

    figures.forEach((fig) => {
      if (fig.dataset.zoomBound === '1') return;
      fig.dataset.zoomBound = '1';

      if (!fig.hasAttribute('tabindex')) fig.setAttribute('tabindex', '0');
      fig.setAttribute('role', 'button');
      const captionEl = fig.querySelector('figcaption');
      const baseLabel = captionEl?.textContent?.trim().split('.')[0];
      fig.setAttribute(
        'aria-label',
        baseLabel ? `Enlarge diagram: ${baseLabel}` : 'Enlarge diagram'
      );

      const open = () => {
        const slot = dialog!.querySelector('.zoom-content')!;
        slot.innerHTML = '';
        const clone = fig.cloneNode(true) as HTMLElement;
        clone.removeAttribute('tabindex');
        clone.removeAttribute('role');
        clone.removeAttribute('aria-label');
        delete (clone as HTMLElement).dataset.zoomBound;
        slot.appendChild(clone);
        if (typeof dialog!.showModal === 'function') {
          dialog!.showModal();
        } else {
          dialog!.setAttribute('open', '');
        }
      };

      fig.addEventListener('click', open);
      fig.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          open();
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDiagramZoom);
  } else {
    initDiagramZoom();
  }

  // Re-init on Astro view transitions / client-side navigation, if used.
  document.addEventListener('astro:page-load', initDiagramZoom);
</script>
