---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { compareEditorialDatesDesc } from '../../utils/dates';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => compareEditorialDatesDesc(a.data.date, b.data.date));

const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
---

<BaseLayout
  title="Writing | Joe Armani"
  description="Writing on AI development, agentic tools, and building software products."
>
  <div class="container">
    <Breadcrumbs items={[
      { label: "Home", href: "/" },
      { label: "Blog" },
    ]} />
    <div class="page-header">
      <h1>Writing</h1>
      <p class="page-header__subtitle">Writing on AI development, agentic tools, and building software products.</p>
    </div>

    {posts.length > 0 ? (
      <>
        <div class="blog-search">
          <div class="blog-search__wrapper">
            <svg class="blog-search__icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input
              type="search"
              class="blog-search__input"
              id="blog-search-input"
              placeholder="Search posts..."
              autocomplete="off"
              aria-label="Search posts"
            />
          </div>
        </div>

        <div class="tag-filter">
          <button class="tag-filter__btn active" data-tag="all">All</button>
          {allTags.map((tag) => (
            <button class="tag-filter__btn" data-tag={tag}>{tag}</button>
          ))}
        </div>

        <div class="post-grid" id="posts-grid">
          {posts.map((post) => (
            <div class="reveal" data-title={post.data.title} data-description={post.data.description}>
              <PostCard
                title={post.data.title}
                description={post.data.description}
                date={post.data.date}
                tags={post.data.tags}
                slug={post.id}
                readingTime={post.data.readingTime}
                headingLevel={2}
              />
            </div>
          ))}
        </div>
      </>
    ) : (
      <p style="color: var(--text-secondary); font-size: 1.05rem; padding: 2rem 0;">First post coming soon. Subscribe to get notified when it drops.</p>
    )}
  </div>
</BaseLayout>

{posts.length > 0 && (
  <script>
    const buttons = document.querySelectorAll('.tag-filter__btn');
    const cards = document.querySelectorAll('#posts-grid .card');
    const searchInput = document.getElementById('blog-search-input');

    if (searchInput instanceof HTMLInputElement) {
      const searchField = searchInput;
      let activeTag = 'all';

      function filterPosts() {
        const query = searchField.value.toLowerCase().trim();

        cards.forEach((card) => {
          const wrapper = card.closest('.reveal') as HTMLElement | null;
          if (!wrapper) return;

          let tagMatch = true;
          if (activeTag !== 'all') {
            const cardTags = card.getAttribute('data-tags')?.split(',') || [];
            tagMatch = cardTags.includes(activeTag);
          }

          let searchMatch = true;
          if (query) {
            const title = (wrapper.getAttribute('data-title') || '').toLowerCase();
            const description = (wrapper.getAttribute('data-description') || '').toLowerCase();
            const tags = (card.getAttribute('data-tags') || '').toLowerCase();
            searchMatch = title.includes(query) || description.includes(query) || tags.includes(query);
          }

          wrapper.style.display = tagMatch && searchMatch ? '' : 'none';
        });
      }

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          buttons.forEach((button) => button.classList.remove('active'));
          btn.classList.add('active');
          activeTag = btn.getAttribute('data-tag') || 'all';
          filterPosts();
        });
      });

      searchField.addEventListener('input', filterPosts);
    }
  </script>
)}
