  description="Writing on agentic development, AI tools, and building products that work."
>
  <div class="container--narrow" style="padding-top: 6rem; padding-bottom: 6rem;">
    <h1 style="text-align: center; margin-bottom: 1rem;">Subscribe</h1>
    <p style="text-align: center; color: var(--text-secondary); margin-bottom: 3rem;">Writing on agentic development, AI tools, and building products that work.</p>
    <Subscribe variant="full" />
  </div>
</BaseLayout>
