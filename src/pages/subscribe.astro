---
import BaseLayout from '../layouts/BaseLayout.astro';
import SubscribeForm from '../components/Subscribe.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<BaseLayout
  title="Subscribe | Joe Armani"
  description="Writing on AI development & agentic tools, buiding & shipping software, and discussing the successes and failures along the way."
>
  <div class="container--narrow" style="padding-top: 6rem; padding-bottom: 6rem;">
    <Breadcrumbs items={[
      { label: "Home", href: "/" },
      { label: "Subscribe" },
    ]} />
    <h1 style="text-align: center; margin-bottom: 1rem;">Subscribe</h1>
    <p style="text-align: center; color: var(--text-secondary); margin-bottom: 3rem;">Writing on AI development & agentic tools, buiding & shipping software, and discussing the successes and failures along the way.</p>
    <SubscribeForm variant="full" />
  </div>
</BaseLayout>
